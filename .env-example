# Example .env file

# OpenAI API Key (for GPT-4o, etc.)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AnythingLLM API Key and URL
ANYTHINGLLM_API_KEY=your_anythingllm_api_key
ANYTHINGLLM_API_URL=http://localhost:3001/api/v1

# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Replit AI API Key and URL
REPLIT_API_KEY=your_replit_api_key
# Default endpoint for Replit AI (change if using a self-hosted or custom endpoint)
REPLIT_API_URL=https://chat.replit.com/v1/chat/completions

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# Groq API Key (fast cloud inference, free tier available)
GROQ_API_KEY=your_groq_api_key

# DeepSeek API Key (strong technical/security reasoning)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Ollama (local inference — no API key required)
# Change the URL if Ollama is running on a different host/port
# OLLAMA_API_URL=http://localhost:11434

# Optional: override the default model for each provider
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-5
# GEMINI_MODEL=gemini-2.0-flash
# REPLIT_MODEL=gpt-4o-mini
# GROQ_MODEL=llama-3.3-70b-versatile
# DEEPSEEK_MODEL=deepseek-chat
# OLLAMA_MODEL=llama3
